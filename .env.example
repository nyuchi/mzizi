# Mzizi — Environment Variables
# Copy this to .env.local and fill in your Supabase credentials.

# ── Supabase (required for database-backed registry) ──────────────────
# Get these from: Supabase Dashboard → Settings → API

# Public client (safe for browser, respects RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only admin key (bypasses RLS). Optional — only needed for write
# operations such as `pnpm registry:sync`. Read endpoints work with the
# anon key alone.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Port (optional, defaults to 11736) ────────────────────────────────
# PORT=11736
