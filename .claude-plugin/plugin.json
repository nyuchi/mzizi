{
  "$schema": "https://docs.claude.com/schemas/claude-code/plugin.json",
  "name": "mzizi",
  "displayName": "Mzizi",
  "version": "1.0.0",
  "description": "Build with Mzizi — an open-architecture project of the Bundu Foundation. Five African Minerals palette, open 3D frontend architecture, Ubuntu doctrine, shadcn-compatible registry. Operated and developed by Nyuchi. Live at mzizi.dev.",
  "homepage": "https://mzizi.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/nyuchi/design-portal"
  },
  "author": {
    "name": "Bundu Foundation"
  },
  "license": "MIT",
  "icons": {
    "light": "https://assets.nyuchi.com/nyuchi-icon-light.png",
    "dark": "https://assets.nyuchi.com/nyuchi-icon-dark.png"
  },
  "skills": [
    "./packages/design-agent-skills/skills/nyuchi-design-system.md",
    "./packages/design-agent-skills/skills/scaffold-component.md",
    "./packages/design-agent-skills/skills/ecosystem-app-setup.md"
  ],
  "mcpServers": {
    "mzizi": {
      "type": "url",
      "url": "https://mzizi.dev/mcp",
      "description": "Mzizi MCP — components, brand tokens, open 3D architecture, skills, changelog. Streamable HTTP transport."
    }
  },
  "permissions": {
    "network": ["mzizi.dev", "assets.nyuchi.com"]
  },
  "keywords": [
    "design-system",
    "open-architecture",
    "mzizi",
    "bundu",
    "shadcn",
    "registry",
    "africa",
    "five-african-minerals",
    "ubuntu",
    "claude-code",
    "mcp"
  ]
}
